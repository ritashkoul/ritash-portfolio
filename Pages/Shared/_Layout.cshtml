@{
    var path = Context.Request.Path.Value ?? "/";
    bool IsActive(string prefix) => prefix == "/"
        ? path == "/"
        : path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    string TabClass(string prefix) => IsActive(prefix) ? "tab active" : "tab";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · Ritash Koul</title>
    <meta name="description" content="Portfolio of an ASP.NET Core developer." />
    <meta name="theme-color" id="theme-color-meta" content="#171b20" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <script src="~/js/theme-init.js" asp-append-version="true"></script>
    <script type="application/ld+json" src="~/schema.json"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <partial name="_Icons" />

    <div class="app-window">
        <header class="tab-bar" role="banner">
            <a href="/" class="brand" aria-label="Home">
                <svg class="icon" aria-hidden="true"><use href="#icon-code"></use></svg>
            </a>

            <nav class="tabs" aria-label="Main navigation">
                <a class="@TabClass("/")" href="/">
                    <svg class="icon" aria-hidden="true"><use href="#icon-eye"></use></svg>
                    <span>About</span>
                </a>
                <a class="@TabClass("/Experience")" href="/Experience">
                    <svg class="icon" aria-hidden="true"><use href="#icon-code"></use></svg>
                    <span>Experience</span>
                </a>
                <a class="@TabClass("/Resume")" href="/Resume">
                    <svg class="icon" aria-hidden="true"><use href="#icon-download"></use></svg>
                    <span>Resume</span>
                </a>
            </nav>

            <div class="header-actions">
                <button type="button" id="theme-toggle" class="btn-icon theme-toggle" title="Toggle light/dark theme" aria-label="Toggle light/dark theme">
                    <svg class="icon icon-sun" aria-hidden="true"><use href="#icon-sun"></use></svg>
                    <svg class="icon icon-moon" aria-hidden="true"><use href="#icon-moon"></use></svg>
                </button>
                <a class="btn-icon" href="~/resume/resume.pdf" download title="Download résumé" aria-label="Download résumé">
                    <svg class="icon" aria-hidden="true"><use href="#icon-download"></use></svg>
                </a>
            </div>
        </header>

        <main class="content" role="main">
            @RenderBody()
        </main>

        <footer class="status-bar" role="contentinfo">
            <div class="status-right social-links">
                <a href="https://www.linkedin.com/in/ritash-koul-a7ab9050/" target="_blank" rel="noopener noreferrer">
                    <svg class="icon icon-sm" aria-hidden="true">
                        <use href="#icon-linkedin"></use>
                    </svg>
                    LinkedIn
                </a>

                <a href="https://www.instagram.com/koulheadedritesh" target="_blank" rel="noopener noreferrer">
                    <svg class="icon icon-sm" aria-hidden="true">
                        <use href="#icon-instagram"></use>
                    </svg>
                    Instagram
                </a>
            </div>
        </footer>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
